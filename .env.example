# ─── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Self URL (used by channel stub to POST callbacks back)
# In dev: http://localhost:3001
# In prod: https://your-backend.railway.app
SELF_URL=http://localhost:3001

# ─── Database (Supabase Postgres) ──────────────────────────
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:E*K*kg*gP2vd%2BKD@db.qarcuxsdqiowuwfueaad.supabase.co:5432/postgres

# ─── Redis (for BullMQ queues) ─────────────────────────────
# Local dev: redis://localhost:6379
# Railway: add a Redis service and use its URL
REDIS_URL=redis://localhost:6379

# ─── AI (Google Gemini) ────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CORS ──────────────────────────────────────────────────
# Frontend URL allowed to call this API
# Dev: http://localhost:3000
# Prod: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000
